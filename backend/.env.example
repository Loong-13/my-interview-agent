APP_ENV=local
APP_NAME=PyOffer Agent API
APP_SECRET_KEY=change_me
ACCESS_TOKEN_EXPIRE_MINUTES=10080

DATABASE_URL=postgresql+psycopg://pyoffer:pyoffer@localhost:5432/pyoffer
REDIS_URL=redis://localhost:6379/0
